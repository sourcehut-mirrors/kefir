KEFIR_DIST_LIBATOMIC_DIR := $(KEFIR_BIN_DIR)/libatomic
KEFIR_DIST_LIBATOMIC_BUILD_DIR := $(KEFIR_DIST_LIBATOMIC_DIR)/build
KEFIR_DIST_LIBATOMIC_CFLAGS := -fPIC -O1
KEFIR_DIST_LIBATOMIC_SO := $(KEFIR_DIST_LIBATOMIC_DIR)/libatomic.so

KEFIR_DIST_COMPILER_RT_VERSION := 21.1.2
KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME := compiler-rt-$(KEFIR_DIST_COMPILER_RT_VERSION).src.tar.xz
KEFIR_DIST_COMPILER_RT_ARCHIVE := $(KEFIR_DIST_LIBATOMIC_DIR)/$(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME)
KEFIR_DIST_COMPILER_RT_SOURCE_DIR := $(KEFIR_DIST_LIBATOMIC_DIR)/compiler-rt-$(KEFIR_DIST_COMPILER_RT_VERSION).src
KEFIR_DIST_COMPILER_RT_URL := https://github.com/llvm/llvm-project/releases/download/llvmorg-$(KEFIR_DIST_COMPILER_RT_VERSION)/$(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME)

KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME_SHA256 := bed7e87f1bbcab27a30f249bf22a6766d5cdd90002ff307dd86a6e33aa01f691

KEFIR_DIST_COMPILER_RT_LIBATOMIC_SOURCE := $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic.c \
										   $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic_flag_clear.c \
										   $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic_flag_clear_explicit.c \
										   $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic_flag_test_and_set.c \
										   $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic_flag_test_and_set_explicit.c \
										   $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic_signal_fence.c \
										   $(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/atomic_thread_fence.c

KEFIR_DIST_COMPILER_RT_LIBATOMIC_OBJECT_FILES := $(KEFIR_DIST_COMPILER_RT_LIBATOMIC_SOURCE:$(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)/lib/builtins/%.c=$(KEFIR_DIST_LIBATOMIC_BUILD_DIR)/%.o)

$(KEFIR_DIST_COMPILER_RT_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_DIST_COMPILER_RT_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_DIST_COMPILER_RT_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_DIST_LIBATOMIC_DIR)/.extracted: $(KEFIR_DIST_COMPILER_RT_ARCHIVE)
	@echo "Extracting $(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_DIST_LIBATOMIC_DIR)" && \
		xz -d < "$(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME)" > "$(basename $(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME))"
	@cd "$(KEFIR_DIST_LIBATOMIC_DIR)" && tar xvf "$(basename $(KEFIR_DIST_COMPILER_RT_ARCHIVE_FILENAME))"
	@echo "Applying $(ROOT)/dist/libatomic/compiler_rt.patch"
	@cd "$(KEFIR_DIST_COMPILER_RT_SOURCE_DIR)" && \
		patch -p0 < "$(realpath $(ROOT))/dist/libatomic/compiler_rt.patch"
	@touch "$@"

$(KEFIR_DIST_LIBATOMIC_SO): $(KEFIR_DIST_LIBATOMIC_DIR)/.extracted $(KEFIR_EXE)
	@mkdir -p "$(shell dirname $@)"
	@echo "Building $@"
	@LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		$(KEFIR_EXE) $(KEFIR_DIST_LIBATOMIC_CFLAGS) -shared -o "$@" $(KEFIR_DIST_COMPILER_RT_LIBATOMIC_SOURCE)

OBJECT_FILES += $(KEFIR_DIST_COMPILER_RT_LIBATOMIC_OBJECT_FILES)
OBJECT_FILES += $(KEFIR_DIST_LIBATOMIC_SO)
