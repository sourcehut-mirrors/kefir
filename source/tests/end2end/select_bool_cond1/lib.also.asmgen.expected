.att_syntax
.section .note.GNU-stack,"",%progbits

.global get
.type get, @function
.global get2
.type get2, @function

.section .text
.L__kefir_text_section_begin:
get:
.L__kefir_text_func_get_begin:
    mov %rsi, %rax
    mov %rdi, %rcx
    test %ecx, %ecx
    setne %dl
    test %eax, %eax
    setne %sil
    and %sil, %dl
    mov %rcx, %rdx
    cmovz %rax, %rdx
    mov %rdx, %rax
    ret
.L__kefir_text_func_get_end:

get2:
.L__kefir_text_func_get2_begin:
    mov %rsi, %rax
    mov %rdi, %rcx
    test %ecx, %ecx
    mov %rdx, %rcx
    setne %cl
    test %eax, %eax
    setne %dl
    mov %rdx, %rsi
    and %cl, %sil
    mov %rsi, %rcx
    movzx %cl, %rcx
    test %cl, %cl
    mov %rcx, %rdx
    cmovz %rax, %rdx
    mov %rdx, %rax
    ret
.L__kefir_text_func_get2_end:

.L__kefir_text_section_end:

