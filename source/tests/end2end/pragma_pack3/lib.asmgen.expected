.section .text
.L__kefir_text_section_begin:
fn:
.L__kefir_text_func_fn_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    movl $100, -4(%rbp)
    call fn
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_fn_end:

fn2:
.L__kefir_text_func_fn2_begin:
    push %rbp
    mov %rsp, %rbp
    call fn2
    call fn2
    call fn2
    pop %rbp
    ret
.L__kefir_text_func_fn2_end:

.L__kefir_text_section_end:

