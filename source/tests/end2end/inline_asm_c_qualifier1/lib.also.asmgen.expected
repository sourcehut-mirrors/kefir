.att_syntax
.section .note.GNU-stack,"",%progbits

.global init
.type init, @function

.section .text
.L__kefir_text_section_begin:
init:
.L__kefir_text_func_init_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    movq %rdi, -8(%rbp)
    movq -8(%rbp), %rax
movl $1, 0(%rax)
movl $2, 16(%rax)
movl $3, 32(%rax)
movl $4, 40(%rax)

    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_init_end:

.L__kefir_text_section_end:

