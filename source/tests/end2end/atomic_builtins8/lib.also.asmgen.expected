.att_syntax
.section .note.GNU-stack,"",%progbits

.global exchange_ptr
.type exchange_ptr, @function

.section .text
.L__kefir_text_section_begin:
exchange_ptr:
.L__kefir_text_func_exchange_ptr_begin:
    mov %rsi, %rax
    mov %rdi, %rcx
    xchgq (%rcx), %rax
    ret
.L__kefir_text_func_exchange_ptr_end:

.L__kefir_text_section_end:

