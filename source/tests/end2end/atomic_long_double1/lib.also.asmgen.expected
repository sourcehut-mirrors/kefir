.att_syntax
.section .note.GNU-stack,"",%progbits

.extern ld1
.global get_ld1
.type get_ld1, @function
.global set_ld1
.type set_ld1, @function

.section .text
.L__kefir_text_section_begin:
get_ld1:
.L__kefir_text_func_get_ld1_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    movq ld1@GOTPCREL(%rip), %rax
    lea -16(%rbp), %rdx
    mov %rax, %rsi
    mov $16, %rdi
    mov $5, %rcx
    call __atomic_load@PLT
    fldt -16(%rbp)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_get_ld1_end:

set_ld1:
.L__kefir_text_func_set_ld1_begin:
    push %rbp
    mov %rsp, %rbp
    sub $32, %rsp
    fstcw -8(%rbp)
    fldt 16(%rbp)
    movq ld1@GOTPCREL(%rip), %rax
    fstpt -32(%rbp)
    mov %rax, %rsi
    lea -32(%rbp), %rdx
    mov $16, %rdi
    mov $5, %rcx
    call __atomic_store@PLT
    fldcw -8(%rbp)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_set_ld1_end:

.L__kefir_text_section_end:

