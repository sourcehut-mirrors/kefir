.att_syntax
.section .note.GNU-stack,"",%progbits

.global get
.type get, @function
.global set
.type set, @function
.global test
.type test, @function
.extern value

.section .text
.L__kefir_text_section_begin:
get:
.L__kefir_text_func_get_begin:
    jmp .L__kefir_func_get_label1
.L__kefir_func_get_label1:
    movq value@GOTPCREL(%rip), %rcx
    mov (%rcx), %rax
    mov 8(%rcx), %rdx
    ret
.L__kefir_text_func_get_end:

set:
.L__kefir_text_func_set_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    jmp .L__kefir_func_set_label1
.L__kefir_func_set_label1:
    movq value@GOTPCREL(%rip), %rax
    mov %rdi, (%rax)
    mov %rsi, 8(%rax)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_set_end:

test:
.L__kefir_text_func_test_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    jmp .L__kefir_func_test_label1
.L__kefir_func_test_label1:
