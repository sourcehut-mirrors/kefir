.att_syntax
.section .note.GNU-stack,"",%progbits

.global mul
.type mul, @function

.section .text
__kefir_text_section_begin:
mul:
__kefir_text_func_mul_begin:
    push %rbp
    mov %rsp, %rbp
    sub $48, %rsp
    fstcw -8(%rbp)
    lea 48(%rbp), %rax
    lea 16(%rbp), %rcx
    fldt 16(%rcx)
    fld %st(0)
    fldt (%rax)
    fldt 16(%rax)
    fmul %st(0), %st(2)
    fldt (%rcx)
    fmul %st(2)
    fsubp %st(3)
    fxch %st(2)
    fxch %st(3)
    fmulp %st(1)
    fldt (%rcx)
    fmulp %st(2)
    faddp %st(1)
    fstpt -32(%rbp)
    fstpt -48(%rbp)
    fldt -32(%rbp)
    fldt -48(%rbp)
    fldcw -8(%rbp)
    lea (%rbp), %rsp
    pop %rbp
    ret
__kefir_text_func_mul_end:

__kefir_text_section_end:

