.att_syntax
.section .note.GNU-stack,"",%progbits

.global clear
.type clear, @function
.global test_and_set
.type test_and_set, @function
.global test_sync_synchronize
.type test_sync_synchronize, @function

.section .text
.L__kefir_text_section_begin:
clear:
.L__kefir_text_func_clear_begin:
    jmp .L__kefir_func_clear_label1
.L__kefir_func_clear_label1:
    xor %eax, %eax
    xchgb %al, (%rdi)
    ret
.L__kefir_text_func_clear_end:

test_and_set:
.L__kefir_text_func_test_and_set_begin:
    jmp .L__kefir_func_test_and_set_label1
.L__kefir_func_test_and_set_label1:
    mov $1, %rax
    xchgb (%rdi), %al
    test %al, %al
    setne %al
    movzx %al, %rax
    ret
.L__kefir_text_func_test_and_set_end:

test_sync_synchronize:
.L__kefir_text_func_test_sync_synchronize_begin:
    jmp .L__kefir_func_test_sync_synchronize_label1
.L__kefir_func_test_sync_synchronize_label1:
    lock     orq $0, (%rsp)
    ret
.L__kefir_text_func_test_sync_synchronize_end:

.L__kefir_text_section_end:

