.L__kefir_text_func_test3_begin:
    push %rbp
    mov %rsp, %rbp
    sub $64, %rsp
    mov %rdx, -16(%rbp)
    mov %rcx, -8(%rbp)
    mov %rdi, -32(%rbp)
    mov %rsi, -24(%rbp)
    mov -32(%rbp), %rax
    mov -24(%rbp), %rcx
    mov -16(%rbp), %rdx
    mov -8(%rbp), %rsi
    add %rdx, %rax
    adc %rsi, %rcx
    mov %rcx, %rdx
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_test3_end:

