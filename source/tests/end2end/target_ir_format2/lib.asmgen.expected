.L__kefir_text_func_test2_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    movl %esi, -8(%rbp)
    movq %rdi, -16(%rbp)
    movl -8(%rbp), %esi
    movq -16(%rbp), %rdi
.L__kefir_func_test2_label2:
    movl (%rdi), %eax
    movsx %eax, %rax
    mov %rax, %r8
    add %esi, %r8d
    mov %rdi, %rdx
    mov %r8d, %ecx
    lock     cmpxchgl %ecx, (%rdx)
    sete %al
    test %al, %al
    jz .L__kefir_func_test2_label4
    mov %r8d, %eax
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_func_test2_label4:
    jmp .L__kefir_func_test2_label2
.L__kefir_text_func_test2_end:

