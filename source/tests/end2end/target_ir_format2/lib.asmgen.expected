__kefir_text_func_test1_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
__kefir_func_test1_label0:
    movb %sil, -1(%rbp)
    movb %dil, -2(%rbp)
    movb -2(%rbp), %al
    movb -1(%rbp), %cl
    movsx %al, %rax
    movsx %cl, %rcx
    cdq
    idiv %ecx
    lea (%rbp), %rsp
    pop %rbp
    ret
__kefir_func_test1_label1:
__kefir_text_func_test1_end:

