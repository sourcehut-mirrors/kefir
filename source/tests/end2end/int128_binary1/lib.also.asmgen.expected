i128_or:
__kefir_text_func_i128_or_begin:
    push %rbp
    mov %rsp, %rbp
    sub $32, %rsp
    or %rdx, %rdi
    or %rcx, %rsi
    mov %rdi, %rax
    mov %rsi, %rdx
    lea (%rbp), %rsp
    pop %rbp
    ret
__kefir_text_func_i128_or_end:

