test:
.L__kefir_text_func_test_begin:
    mov %rsi, %rax
    shl $57, %rax
    sar $57, %rax
    mov %rdx, %rcx
    shl $57, %rcx
    sar $57, %rcx
    add %cl, %al
    shl $57, %rax
    sar $57, %rax
    add %edx, %esi
    test %dil, %dil
    cmovnz %rsi, %rax
    ret
.L__kefir_text_func_test_end:

