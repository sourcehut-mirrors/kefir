    and %edx, %eax
    ret
.L__kefir_text_func_and_end:

mul:
.L__kefir_text_func_mul_begin:
    shl $45, %rsi
    sar $45, %rsi
    shl $45, %rdx
    sar $45, %rdx
    mov %rsi, %rax
    imul %edx, %eax
    ret
.L__kefir_text_func_mul_end:

shl:
.L__kefir_text_func_shl_begin:
    shl $45, %rdx
    mov %rdx, %rcx
    sar $45, %rcx
    mov %rsi, %rax
    shl %cl, %eax
    ret
.L__kefir_text_func_shl_end:

