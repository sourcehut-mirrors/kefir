.att_syntax
.section .note.GNU-stack,"",%progbits

.extern get
.extern leak
.global test
.type test, @function

.section .text
__kefir_text_section_begin:
test:
__kefir_text_func_test_begin:
    push %rbp
    mov %rsp, %rbp
    push %rbx
    push %r12
    sub $16, %rsp
    mov %rdi, %r12
    jmp __kefir_func_test_label1
__kefir_func_test_label1:
    mov %rsi, %rbx
    movb $0, -17(%rbp)
    leaq -17(%rbp), %rdi
    call leak@PLT
    mov %rbx, %rsi
    not %rsi
    mov %r12, %rbx
    mov %rbx, %rdi
    call get@PLT
    mov %r12, %rax
    lea -16(%rbp), %rsp
    pop %r12
    pop %rbx
    pop %rbp
    ret
__kefir_text_func_test_end:

__kefir_text_section_end:

