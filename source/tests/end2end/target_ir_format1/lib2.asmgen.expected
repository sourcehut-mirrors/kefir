.L__kefir_text_func_factorial_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    movl %edi, -8(%rbp)
    movl -8(%rbp), %eax
    cmp $0, %eax
    setl %al
    test %al, %al
    jnz .L__kefir_func_factorial_label14
    movl -8(%rbp), %eax
    mov $0, %rcx
    cmp $2, %eax
    setl %cl
    mov $0, %rdx
    mov $2, %esi
    cmp %eax, %esi
    sete %dl
    or %rdx, %rcx
    setne %al
    test %al, %al
    jnz .L__kefir_func_factorial_label12
    movl $1, -4(%rbp)
.L__kefir_func_factorial_label6:
    movl -8(%rbp), %eax
    cmp $1, %eax
    setg %al
    test %al, %al
    jnz .L__kefir_func_factorial_label10
    movl -4(%rbp), %eax
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_func_factorial_label10:
    movl -8(%rbp), %eax
    movl -4(%rbp), %ecx
    imul %eax, %ecx
    movl %ecx, -4(%rbp)
    movl -8(%rbp), %eax
    add $-1, %eax
    movl %eax, -8(%rbp)
    jmp .L__kefir_func_factorial_label6
.L__kefir_func_factorial_label12:
    movl -8(%rbp), %eax
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_func_factorial_label14:
    mov $0, %rax
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_factorial_end:

