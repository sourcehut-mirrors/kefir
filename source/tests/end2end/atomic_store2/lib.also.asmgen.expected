.section .text
.L__kefir_text_section_begin:
store_b:
.L__kefir_text_func_store_b_begin:
    mov %rsi, %rax
    mov %rdi, %rcx
    xchgb (%rcx), %al
    ret
.L__kefir_text_func_store_b_end:

store_u8:
.L__kefir_text_func_store_u8_begin:
    mov %rsi, %rax
