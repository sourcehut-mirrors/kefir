.L__kefir_text_func_store_u8_end:

store_f32:
.L__kefir_text_func_store_f32_begin:
    mov %rdi, %rcx
    movq %xmm0, %rax
    xchgl (%rcx), %eax
    ret
.L__kefir_text_func_store_f32_end:

store_f64:
.L__kefir_text_func_store_f64_begin:
    mov %rdi, %rcx
