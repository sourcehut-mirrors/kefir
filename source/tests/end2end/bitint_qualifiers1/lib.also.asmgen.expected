.att_syntax
.section .note.GNU-stack,"",%progbits

.global add
.type add, @function
.global get
.type get, @function
.global value
.type value, @object

.section .text
.L__kefir_text_section_begin:
add:
.L__kefir_text_func_add_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    mov %rsi, %rax
    mov %rdi, %rcx
    movq %rax, -16(%rbp)
    movq %rcx, -8(%rbp)
    movq -16(%rbp), %rax
    movq -8(%rbp), %rcx
    movq (%rcx), %rdx
    shl $21, %rdx
    sar $21, %rdx
    shl $21, %rax
    sar $21, %rax
    mov %rdx, %rsi
    add %rax, %rsi
    mov %rsi, %rax
    movq %rax, (%rcx)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_add_end:

get:
.L__kefir_text_func_get_begin:
    push %rbp
    mov %rsp, %rbp
    movq value@GOTPCREL(%rip), %rax
    pop %rbp
    ret
.L__kefir_text_func_get_end:

.L__kefir_text_section_end:

.section .data
    .align 8
value:
    .quad 0

