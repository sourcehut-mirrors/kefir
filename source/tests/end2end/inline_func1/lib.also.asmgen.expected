.att_syntax
.section .note.GNU-stack,"",%progbits

.global hypot_sq
.type hypot_sq, @function

.section .text
.L__kefir_text_section_begin:
hypot_sq:
.L__kefir_text_func_hypot_sq_begin:
    mov %rsi, %rax
