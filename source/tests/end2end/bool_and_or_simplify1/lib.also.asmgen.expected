.L__kefir_text_func_or_end:

and:
.L__kefir_text_func_and_begin:
    mov %rsi, %rax
    mov %rdi, %rcx
    test %ecx, %ecx
    mov %rdx, %rcx
    setne %cl
    test %eax, %eax
    mov %rdx, %rax
    setne %al
    and %cl, %al
    movzx %al, %rax
    ret
.L__kefir_text_func_and_end:

.L__kefir_text_section_end:

