.L__kefir_text_section_begin:
or:
.L__kefir_text_func_or_begin:
    mov %rsi, %rax
    mov %rdi, %rcx
    or %eax, %ecx
    setne %cl
    movzx %cl, %rcx
    or %eax, %ecx
    setne %cl
    movzx %cl, %rcx
    mov %rcx, %rdx
    or %eax, %edx
    mov %rdx, %rax
    setne %al
