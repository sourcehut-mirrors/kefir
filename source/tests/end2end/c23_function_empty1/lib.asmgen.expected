.att_syntax
.section .note.GNU-stack,"",%progbits

.extern test
.extern test2
.global test3
.type test3, @function
.global test4
.type test4, @function

.section .text
.L__kefir_text_section_begin:
test3:
.L__kefir_text_func_test3_begin:
    jmp test@PLT
.L__kefir_text_func_test3_end:

test4:
.L__kefir_text_func_test4_begin:
    push %rbp
    mov %rsp, %rbp
    mov $1, %edi
    mov $2, %esi
    mov $3, %edx
    mov $4, %ecx
    xor %eax, %eax
    call test2@PLT
    pop %rbp
    ret
.L__kefir_text_func_test4_end:

.L__kefir_text_section_end:

