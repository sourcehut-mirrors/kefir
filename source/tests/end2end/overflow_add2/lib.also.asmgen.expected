.L__kefir_text_func_overflow_sadd_begin:
    movsx %edi, %rax
    movsx %esi, %rcx
    add %rcx, %rax
    mov %rsi, %rcx
    seto %cl
    movsx %eax, %rsi
    cmp %rsi, %rax
    setne %sil
    or %sil, %cl
    and $1, %ecx
    movl %eax, (%rdx)
    mov %rcx, %rax
    ret
.L__kefir_text_func_overflow_sadd_end:

