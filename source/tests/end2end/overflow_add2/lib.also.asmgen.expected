.section .text
.L__kefir_text_section_begin:
overflow_sadd:
.L__kefir_text_func_overflow_sadd_begin:
    movsx %edi, %rax
    movsx %esi, %rcx
    add %rcx, %rax
    seto %sil
    movsx %eax, %rcx
    cmp %rcx, %rax
    mov %rsi, %rcx
    setne %cl
    or %cl, %sil
    and $1, %esi
    movl %eax, (%rdx)
    mov %rsi, %rax
    ret
.L__kefir_text_func_overflow_sadd_end:

overflow_uadd:
.L__kefir_text_func_overflow_uadd_begin:
    mov %edi, %eax
    mov %esi, %ecx
    add %rcx, %rax
    seto %sil
    mov %eax, %ecx
    cmp %rcx, %rax
    mov %rsi, %rcx
    setne %cl
    or %cl, %sil
    and $1, %esi
    movl %eax, (%rdx)
    mov %rsi, %rax
    ret
.L__kefir_text_func_overflow_uadd_end:

overflow_saddl:
.L__kefir_text_func_overflow_saddl_begin:
    add %rsi, %rdi
    seto %al
    and $1, %eax
    movq %rdi, (%rdx)
    ret
.L__kefir_text_func_overflow_saddl_end:

overflow_uaddl:
.L__kefir_text_func_overflow_uaddl_begin:
    add %rsi, %rdi
    setc %al
    and $1, %eax
    movq %rdi, (%rdx)
    ret
.L__kefir_text_func_overflow_uaddl_end:

overflow_saddll:
.L__kefir_text_func_overflow_saddll_begin:
    add %rsi, %rdi
    seto %al
    and $1, %eax
    movq %rdi, (%rdx)
    ret
.L__kefir_text_func_overflow_saddll_end:

overflow_uaddll:
.L__kefir_text_func_overflow_uaddll_begin:
    add %rsi, %rdi
    setc %al
    and $1, %eax
    movq %rdi, (%rdx)
