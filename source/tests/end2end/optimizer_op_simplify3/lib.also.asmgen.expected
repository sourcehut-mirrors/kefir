.L__kefir_text_section_begin:
ulong2uint:
.L__kefir_text_func_ulong2uint_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    mov %rdi, %rax
    movq %rax, -8(%rbp)
    movq -8(%rbp), %rax
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_ulong2uint_end:

