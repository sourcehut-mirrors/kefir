.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
.L__kefir_text_section_begin:
test:
.L__kefir_text_func_test_begin:
    xor %eax, %eax
    cmp $0, %edi
    setg %al
    xor %edi, %edi
    cmp $1, %esi
    mov %rdi, %rsi
    setge %sil
    or %sil, %al
    setne %al
    xor %esi, %esi
    cmp $0, %edx
    mov %rsi, %rdx
    setne %dl
    or %dl, %al
    setne %al
    test %ecx, %ecx
    mov %rdx, %rcx
    sete %cl
    or %cl, %al
    setne %al
    movzx %al, %rax
    ret
.L__kefir_text_func_test_end:

.L__kefir_text_section_end:

