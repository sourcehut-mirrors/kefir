.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
.L__kefir_text_section_begin:
test:
.L__kefir_text_func_test_begin:
    cmp $0, %edi
    setg %al
    cmp $1, %esi
    setge %sil
    or %sil, %al
    setne %al
    cmp $0, %edx
    setne %dl
    or %dl, %al
    setne %al
    test %ecx, %ecx
    sete %cl
    or %cl, %al
    setne %al
    movzx %al, %rax
    ret
.L__kefir_text_func_test_end:

.L__kefir_text_section_end:

