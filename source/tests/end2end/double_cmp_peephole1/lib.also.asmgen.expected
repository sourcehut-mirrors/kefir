.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
__kefir_text_section_begin:
test:
__kefir_text_func_test_begin:
    xor %eax, %eax
    cmp $0, %edi
    setg %al
    jg __kefir_func_test_label4
__kefir_func_test_label2:
    ret
__kefir_func_test_label4:
    movl (%rsi), %ecx
    xor %eax, %eax
    cmp $0, %ecx
    setg %al
    jmp __kefir_func_test_label2
__kefir_text_func_test_end:

__kefir_text_section_end:

