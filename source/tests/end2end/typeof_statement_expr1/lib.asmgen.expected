.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
.L__kefir_text_section_begin:
test:
.L__kefir_text_func_test_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    movl %esi, -4(%rbp)
    movl %edi, -8(%rbp)
    movl $0, -12(%rbp)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_test_end:

.L__kefir_text_section_end:

