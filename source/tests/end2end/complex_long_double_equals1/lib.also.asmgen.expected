.att_syntax
.section .note.GNU-stack,"",%progbits

.global cld_eq
.type cld_eq, @function
.global cld_trunc
.type cld_trunc, @function

.section .text
.L__kefir_text_section_begin:
cld_eq:
.L__kefir_text_func_cld_eq_begin:
    push %rbp
    mov %rsp, %rbp
    sub $48, %rsp
    fstcw -8(%rbp)
    lea 48(%rbp), %rax
    lea 16(%rbp), %rcx
    fldt (%rcx)
    fldt (%rax)
    fxch %st(1)
    xor %edx, %edx
    xor %esi, %esi
    fucomip %st(1)
    fstp %st(0)
    setnp %dl
    cmovne %rsi, %rdx
    fldt 16(%rcx)
    fldt 16(%rax)
    fxch %st(1)
    xor %eax, %eax
    xor %ecx, %ecx
    fucomip %st(1)
    fstp %st(0)
    setnp %al
    cmovne %rcx, %rax
    mov %rdx, %rcx
    and %rax, %rcx
    mov %rcx, %rax
    test %eax, %eax
    mov %rcx, %rax
    setne %al
    movzx %al, %rax
    fldcw -8(%rbp)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_cld_eq_end:

cld_trunc:
.L__kefir_text_func_cld_trunc_begin:
    push %rbp
    mov %rsp, %rbp
    sub $48, %rsp
    fstcw -8(%rbp)
    lea 16(%rbp), %rax
    fldt (%rax)
    fldt 16(%rax)
    fldz
    fucomi %st(1)
    fstp %st(0)
    setp %al
    mov %rax, %rcx
    setne %cl
    or %al, %cl
    fxch %st(1)
    fldz
    fucomi %st(1)
    fstp %st(0)
    setp %al
    setne %dl
    mov %rdx, %rsi
    or %al, %sil
    mov %rsi, %rax
    or %cl, %al
    fstp %st(0)
    fstp %st(0)
    fldcw -8(%rbp)
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_cld_trunc_end:

.L__kefir_text_section_end:

