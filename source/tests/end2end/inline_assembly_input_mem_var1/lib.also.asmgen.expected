.att_syntax
.section .note.GNU-stack,"",%progbits

.global add
.type add, @function
.global add2
.type add2, @function

.section .text
.L__kefir_text_section_begin:
add:
.L__kefir_text_func_add_begin:
    push %rbp
    mov %rsp, %rbp
    mov %rsi, %rax
    mov %rdi, %rcx
    pushfq
    sub $8, %rsp
addq  %rax, (%rcx)
    add $8, %rsp
    popfq
    pop %rbp
    ret
.L__kefir_text_func_add_end:

add2:
.L__kefir_text_func_add2_begin:
    push %rbp
    mov %rsp, %rbp
    mov %rsi, %rax
    mov %rdi, %rcx
    pushfq
    sub $8, %rsp
addq  %rax, (%rcx)
    add $8, %rsp
    popfq
    pop %rbp
    ret
.L__kefir_text_func_add2_end:

.L__kefir_text_section_end:

