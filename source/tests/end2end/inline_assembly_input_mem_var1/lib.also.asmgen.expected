.section .text
.L__kefir_text_section_begin:
add:
.L__kefir_text_func_add_begin:
    push %rbp
    mov %rsp, %rbp
    sub $16, %rsp
    mov %rsi, %rax
    mov %rdi, %rcx
    movq %rax, -8(%rbp)
    pushfq
    sub $8, %rsp
    mov -8(%rbp), %rax
addq  %rax, (%rcx)
    add $8, %rsp
    popfq
    mov %rax, -8(%rbp)
    movq -8(%rbp), %rax
    lea (%rbp), %rsp
    pop %rbp
    ret
.L__kefir_text_func_add_end:

