.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
__kefir_text_section_begin:
test:
__kefir_text_func_test_begin:
    jmp __kefir_func_test_label1
__kefir_func_test_label1:
    xor %eax, %eax
    cmp $0, %edi
    setg %al
    xor %edi, %edi
    cmp $1, %esi
    mov %rdi, %rsi
    setge %sil
    and %sil, %al
    xor %esi, %esi
    cmp $0, %edx
    mov %rsi, %rdx
    setne %dl
    and %dl, %al
    test %ecx, %ecx
    sete %cl
    and %al, %cl
    movzx %cl, %rax
    ret
__kefir_text_func_test_end:

__kefir_text_section_end:

