.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
.L__kefir_text_section_begin:
test:
.L__kefir_text_func_test_begin:
    xor %eax, %eax
    cmp $0, %edi
    setg %al
    xor %edi, %edi
    cmp $1, %esi
    setge %dil
    and %dil, %al
    xor %esi, %esi
    cmp $0, %edx
    setne %sil
    and %sil, %al
    test %ecx, %ecx
    sete %dl
    and %al, %dl
    movzx %dl, %rax
    ret
.L__kefir_text_func_test_end:

.L__kefir_text_section_end:

