.att_syntax
.section .note.GNU-stack,"",%progbits

.global test
.type test, @function

.section .text
.L__kefir_text_section_begin:
test:
.L__kefir_text_func_test_begin:
    cmp $0, %edi
    setg %al
    cmp $1, %esi
    setge %sil
    and %sil, %al
    cmp $0, %edx
    setne %dl
    and %dl, %al
    test %ecx, %ecx
    sete %cl
    and %al, %cl
    movzx %cl, %rax
    ret
.L__kefir_text_func_test_end:

.L__kefir_text_section_end:

