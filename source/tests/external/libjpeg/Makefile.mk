
KEFIR_EXTERNAL_TEST_LIBJPEG_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libjpeg

KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION := 10
KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_FILENAME := jpegsrc.v$(KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBJPEG_DIR)/$(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBJPEG_DIR)/jpeg-$(KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION)
KEFIR_EXTERNAL_TEST_LIBJPEG_URL := https://www.ijg.org/files/$(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_SHA256 := 8b9eaa13242690ebd03e1728ab1edf97a81a78ed6e83624d493655f31ac95ab5

$(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBJPEG_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBJPEG_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBJPEG_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_LIBJPEG_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring libjpeg $(KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)/djpeg: $(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)/Makefile
	@echo "Building libjpeg $(KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_LIBJPEG_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)/djpeg
	@echo "Testing libjpeg $(KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBJPEG_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		CFLAGS="" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/libjpeg.test.done: $(KEFIR_EXTERNAL_TEST_LIBJPEG_DIR)/tests.log
	@touch "$@"
	@echo "libjpeg-$(KEFIR_EXTERNAL_TEST_LIBJPEG_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libjpeg.test.done
