
KEFIR_EXTERNAL_TEST_SLIMCC_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/slimcc

KEFIR_EXTERNAL_TEST_SLIMCC_VERSION := 2f4d90651bcb3b6cd4cba958baaeab15116d7e7b
KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION).zip
KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE := $(KEFIR_EXTERNAL_TEST_SLIMCC_DIR)/$(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_SLIMCC_DIR)/slimcc-$(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION)
KEFIR_EXTERNAL_TEST_SLIMCC_URL := https://github.com/fuhsnn/slimcc/archive/$(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_SHA256 := 5c1dcbf4097ce58157fbdc9d8bcb5d639c9760eaf5007a7a41af28e46b34a5ba

$(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_SLIMCC_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_SLIMCC_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE)
	@rm -rf "$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)"
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_SLIMCC_DIR)" && \
		unzip "$(KEFIR_EXTERNAL_TEST_SLIMCC_ARCHIVE_FILENAME)"
	@echo "Patching slimcc $(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/slimcc/slimcc-$(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION).patch"
	@echo "Configuring slimcc $(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION)..."
	@ln -s platform/linux-glibc-generic.c "$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)/platform.c"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)/slimcc: $(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building slimcc $(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_SLIMCC_DIR)/test.log: $(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)/slimcc
	@echo "Testing slimcc $(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_SLIMCC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) test | tee "$(shell realpath $@.tmp)"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/slimcc.test.done: $(KEFIR_EXTERNAL_TEST_SLIMCC_DIR)/test.log
	@$(SOURCE_DIR)/tests/external/slimcc/validate.sh "$(KEFIR_EXTERNAL_TEST_SLIMCC_DIR)/test.log"
	@touch "$@"
	@echo "Successfully tested slimcc $(KEFIR_EXTERNAL_TEST_SLIMCC_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/slimcc.test.done
