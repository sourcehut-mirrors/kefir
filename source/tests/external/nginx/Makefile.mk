KEFIR_EXTERNAL_TEST_NGINX_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/nginx

KEFIR_EXTERNAL_TEST_NGINX_VERSION := 1.29.6
KEFIR_EXTERNAL_TEST_NGINX_TESTS_VERSION := a7878c072022b3be4e49638618d3ffbf43220760
KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE := nginx-$(KEFIR_EXTERNAL_TEST_NGINX_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_NGINX_TESTS_VERSION).zip
KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_NGINX_DIR)/nginx-$(KEFIR_EXTERNAL_TEST_NGINX_VERSION)
KEFIR_EXTERNAL_TEST_NGINX_TESTS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_NGINX_DIR)/nginx-tests-$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_VERSION)
KEFIR_EXTERNAL_TEST_NGINX_URL := https://nginx.org/download/$(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE)
KEFIR_EXTERNAL_TEST_NGINX_TESTS_URL := https://github.com/nginx/nginx-tests/archive/$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE)

KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE_SHA256=316f298cd9f061d6d0679696152710285b72f75d88eb1f7e323f40c5c52fe0d7
KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE_SHA256=680eeaa171162ab2998e9b3a82b66aedd033b269eac7c604eb217834db00a5ff

KEFIR_EXTERAL_TEST_NGINX_EXE := $(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)/objs/nginx

$(KEFIR_EXTERNAL_TEST_NGINX_DIR)/$(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE):
	@mkdir -p $(shell dirname $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_NGINX_URL)..."
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_NGINX_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_NGINX_DIR)/$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE):
	@mkdir -p $(shell dirname $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_NGINX_TESTS_URL)..."
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_NGINX_DIR)/$(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE)..."
	@rm -rf "$(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)"
	@cd "$(KEFIR_EXTERNAL_TEST_NGINX_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_NGINX_DIR)/$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_NGINX_ARCHIVE)..."
	@rm -rf "$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_SOURCE_DIR)"
	@cd "$(KEFIR_EXTERNAL_TEST_NGINX_DIR)" && unzip "$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_ARCHIVE)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring Nginx $(KEFIR_EXTERNAL_TEST_NGINX_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(shell $(REALPATH) $(LIB_DIR)):$$LD_LIBRARY_PATH" \
		KEFIR_RTINC="$(shell $(REALPATH) $(HEADERS_DIR)/kefir/runtime)" \
		CC="$(shell $(REALPATH) $(KEFIR_EXE))" \
		CFLAGS="-O1 -g -isystem $(realpath $(SOURCE_DIR))/tests/external/nginx/include" \
		./configure
	@touch "$@"

$(KEFIR_EXTERAL_TEST_NGINX_EXE): $(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)/Makefile
	@echo "Building Nginx $(KEFIR_EXTERNAL_TEST_NGINX_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_NGINX_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(shell $(REALPATH) $(LIB_DIR)):$$LD_LIBRARY_PATH" \
		KEFIR_RTINC="$(shell $(REALPATH) $(HEADERS_DIR)/kefir/runtime)" \
		CC="$(shell $(REALPATH) $(KEFIR_EXE))" \
		CFLAGS="-O1 -g -isystem $(realpath $(SOURCE_DIR))/tests/external/nginx/include" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_NGINX_DIR)/tests.log: $(KEFIR_EXTERAL_TEST_NGINX_EXE) $(KEFIR_EXTERNAL_TEST_NGINX_TESTS_SOURCE_DIR)/.extracted
	@echo "Testing Nginx $(KEFIR_EXTERNAL_TEST_NGINX_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_NGINX_TESTS_SOURCE_DIR)" && \
		bash -c 'set -o pipefail; TEST_NGINX_BINARY="$(realpath $(KEFIR_EXTERAL_TEST_NGINX_EXE))" prove . 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/nginx.test.done: $(KEFIR_EXTERNAL_TEST_NGINX_DIR)/tests.log
	@"$(SOURCE_DIR)/tests/external/nginx/validate.sh" "$(KEFIR_EXTERNAL_TEST_NGINX_DIR)/tests.log"
	@touch "$@"
	@echo "Successfully tested Nginx $(KEFIR_EXTERNAL_TEST_NGINX_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/nginx.test.done
