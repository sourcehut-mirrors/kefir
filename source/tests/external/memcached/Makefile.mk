
KEFIR_EXTERNAL_TEST_MEMCACHED_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/memcached

KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION := 1.6.41
KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE := $(KEFIR_EXTERNAL_TEST_MEMCACHED_DIR)/$(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_MEMCACHED_DIR)/memcached-$(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION)
KEFIR_EXTERNAL_TEST_MEMCACHED_URL := https://github.com/memcached/memcached/archive/refs/tags/$(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_SHA256 := c0772ab998a3ed542124fc81873a40f5652d268532417277276a80b3f4ffffc7

$(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_MEMCACHED_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_MEMCACHED_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MEMCACHED_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_FILENAME)"
	@echo "Patching $(KEFIR_EXTERNAL_TEST_MEMCACHED_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/memcached/memcached.patch"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/configure: $(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Autogen memcached $(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		sh autogen.sh

$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/configure
	@echo "Configuring memcached $(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/memcached: $(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/Makefile
	@echo "Building memcached $(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_MEMCACHED_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)/memcached
	@echo "Testing memcached $(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MEMCACHED_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) test 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/memcached.test.done: $(KEFIR_EXTERNAL_TEST_MEMCACHED_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/memcached/validate.sh "$(KEFIR_EXTERNAL_TEST_MEMCACHED_DIR)/tests.log"
	@touch "$@"
	@echo "memcached $(KEFIR_EXTERNAL_TEST_MEMCACHED_VERSION) test successfully finished"

EXTERNAL_TESTS_SLOW_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/memcached.test.done
