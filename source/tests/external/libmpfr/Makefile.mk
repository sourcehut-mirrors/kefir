
KEFIR_EXTERNAL_TEST_LIBMPFR_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libmpfr

KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION := 4.2.2
KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE_FILENAME := mpfr-$(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBMPFR_DIR)/mpfr-$(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBMPFR_URL := https://gnuftp.uib.no/mpfr/$(KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBMPFR_DIR)/mpfr-$(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION)

KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE_SHA256 := 826cbb24610bd193f36fde172233fb8c009f3f5c2ad99f644d0dea2e16a20e42

$(KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBMPFR_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBMPFR_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPFR_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_LIBMPFR_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring libmpfr $(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)/src/.libs/libmpfr.a: $(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)/Makefile
	@echo "Building libmpfr $(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_LIBMPFR_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)/src/.libs/libmpfr.a
	@echo "Testing libmpfr $(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPFR_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/libmpfr.test.done: $(KEFIR_EXTERNAL_TEST_LIBMPFR_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/libmpfr/validate.sh "$(KEFIR_EXTERNAL_TEST_LIBMPFR_DIR)/tests.log"
	@touch "$@"
	@echo "libmpfr $(KEFIR_EXTERNAL_TEST_LIBMPFR_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libmpfr.test.done
