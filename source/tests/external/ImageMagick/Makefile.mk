
KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/ImageMagick

KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION := 7.1.2-16
KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE := $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR)/$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR)/ImageMagick-$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION)
KEFIR_EXTERNAL_TEST_IMAGEMAGICK_URL := https://github.com/ImageMagick/ImageMagick/archive/refs/tags/$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_SHA256 := aadfa67a104d14a35339de0f2cc286c973a0f43329770c69e9667a22208750fb

$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configure ImageMagick $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION)..."
	@mkdir -p "$(shell dirname $@)"
	@cd "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)/MagickCore/libMagickCore-7.Q16HDRI.la: $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)/Makefile
	@echo "Building ImageMagick $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)/MagickCore/libMagickCore-7.Q16HDRI.la
	@echo "Testing ImageMagick $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/ImageMagick.test.done: $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR)/tests.log
	@"$(SOURCE_DIR)/tests/external/ImageMagick/validate.sh" "$(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_DIR)/tests.log"
	@touch "$@"
	@echo "ImageMagick $(KEFIR_EXTERNAL_TEST_IMAGEMAGICK_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/ImageMagick.test.done
