
KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/openpcells

KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION := f5bac2ed2992743aa3afe23c15367e7767d637e6
KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION).zip
KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR)/$(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR)/openPCells-$(KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION)
KEFIR_EXTERNAL_TEST_OPENPCELLS_URL := https://github.com/patrickschulz/openPCells/archive/$(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_SHA256 := 75f8ef89d2a9a8f863fee803cf7abd0721c59b627dd3de5a58986ac97329f25c

$(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_OPENPCELLS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_FILENAME)..."
	@rm -rf "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)"
	@cd "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR)" && unzip "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_ARCHIVE_FILENAME)"
	@echo "Patching $(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/configure.sh"
	@sed -i '1i #!/usr/bin/env bash' "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/configure.sh"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Build openPCells $(KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR)):$$LD_LIBRARY_PATH" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure.sh --all-load-paths-local

$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/opc: $(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/Makefile
	@echo "Build openPCells $(KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR)):$$LD_LIBRARY_PATH" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		$(MAKE) CC="$(realpath $(KEFIR_EXE))"

$(KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)/opc
	@echo "Testing openPCells $(KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_SOURCE_DIR)" && \
		bash -c 'set -o pipefail; "$(realpath $(SOURCE_DIR))"/tests/external/openPCells/test.sh 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/openPCells.test.done: $(KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/openPCells/validate.sh "$(KEFIR_EXTERNAL_TEST_OPENPCELLS_DIR)/tests.log"
	@touch "$@"
	@echo "openPCells $(KEFIR_EXTERNAL_TEST_OPENPCELLS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/openPCells.test.done
