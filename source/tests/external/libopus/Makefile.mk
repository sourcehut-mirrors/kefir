
KEFIR_EXTERNAL_TEST_LIBOPUS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libopus

KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION := 1.5.2
KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_FILENAME := opus-$(KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBOPUS_DIR)/$(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBOPUS_DIR)/opus-$(KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION)
KEFIR_EXTERNAL_TEST_LIBOPUS_URL := https://github.com/xiph/opus/releases/download/v$(KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION)/$(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_SHA256 := 65c1d2f78b9f2fb20082c38cbe47c951ad5839345876e46941612ee87f9a7ce1

$(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBOPUS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBOPUS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBOPUS_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_FILENAME)"
	@echo "Patching libopus $(KEFIR_EXTERNAL_TEST_LIBOPUS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/libopus/libopus.patch"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Build libopus $(KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/.libs/opus_demo: $(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/Makefile
	@echo "Build libopus $(KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/.libs/opus_demo
	@echo "Testing libopus $(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/libopus.test.done: $(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/libopus/validate.sh "$(KEFIR_EXTERNAL_TEST_LIBOPUS_SOURCE_DIR)/tests.log"
	@touch "$@"
	@echo "libopus $(KEFIR_EXTERNAL_TEST_LIBOPUS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libopus.test.done
