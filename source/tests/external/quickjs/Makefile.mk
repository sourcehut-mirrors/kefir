
KEFIR_EXTERNAL_TEST_QUICKJS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/quickjs

KEFIR_EXTERNAL_TEST_QUICKJS_VERSION := f1139494d18a2053630c5ed3384a42bb70db3c53
KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_QUICKJS_VERSION).zip
KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_QUICKJS_DIR)/$(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_QUICKJS_DIR)/quickjs-$(KEFIR_EXTERNAL_TEST_QUICKJS_VERSION)
KEFIR_EXTERNAL_TEST_QUICKJS_URL := https://github.com/bellard/quickjs/archive/$(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_SHA256 := 51fb52c78c744be97162ae6930477fee24d148097e633120f4e87c1c95cca617

$(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_QUICKJS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_QUICKJS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_QUICKJS_DIR)" && unzip "$(KEFIR_EXTERNAL_TEST_QUICKJS_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR)/qjs: $(KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building quickjs $(KEFIR_EXTERNAL_TEST_QUICKJS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) CC="$(realpath $(KEFIR_EXE))"

$(KEFIR_EXTERNAL_TEST_QUICKJS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR)/qjs
	@echo "Testing quickjs $(KEFIR_EXTERNAL_TEST_QUICKJS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_QUICKJS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) CC="$(realpath $(KEFIR_EXE))" test 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/quickjs.test.done: $(KEFIR_EXTERNAL_TEST_QUICKJS_DIR)/tests.log
	@touch "$@"
	@echo "quickjs $(KEFIR_EXTERNAL_TEST_QUICKJS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/quickjs.test.done
