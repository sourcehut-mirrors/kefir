
KEFIR_EXTERNAL_TEST_NANO_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/nano

KEFIR_EXTERNAL_TEST_NANO_VERSION := 8.7.1
KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_FILENAME := nano-$(KEFIR_EXTERNAL_TEST_NANO_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_NANO_ARCHIVE := $(KEFIR_EXTERNAL_TEST_NANO_DIR)/$(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_NANO_DIR)/nano-$(KEFIR_EXTERNAL_TEST_NANO_VERSION)
KEFIR_EXTERNAL_TEST_NANO_URL := https://www.nano-editor.org/dist/v8/$(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_SHA256 := f56b612024beb5900905a0580260434cf74a4dcdace8241608ff28ae2f472118

$(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_NANO_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_NANO_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE)
	@echo "Extracnanog $(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_NANO_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_NANO_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring nano $(KEFIR_EXTERNAL_TEST_NANO_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		CFLAGS="-O1 -fPIC -pie" \
		./configure

$(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)/src/nano: $(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)/Makefile
	@echo "Building nano $(KEFIR_EXTERNAL_TEST_NANO_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		$(MAKE)

$(KEFIR_EXTERNAL_TESTS_DIR)/nano.test.done: $(KEFIR_EXTERNAL_TEST_NANO_SOURCE_DIR)/src/nano
	@touch "$@"
	@echo "Successfully built nano $(KEFIR_EXTERNAL_TEST_NANO_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/nano.test.done
