
KEFIR_EXTERNAL_TEST_FINDUTILS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/findutils

KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION := 4.10.0
KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE_FILENAME := findutils-$(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION).tar.xz
KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_FINDUTILS_DIR)/findutils-$(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION).tar.xz
KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_FINDUTILS_DIR)/findutils-$(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION)
KEFIR_EXTERNAL_TEST_FINDUTILS_URL := https://gnuftp.uib.no/findutils/$(KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE_SHA256 := 1387e0b67ff247d2abde998f90dfbf70c1491391a59ddfecb8ae698789f0a4f5

$(KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_FINDUTILS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_FINDUTILS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FINDUTILS_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_FINDUTILS_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring findutils $(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)/find/find: $(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)/Makefile
	@echo "Building findutils $(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_FINDUTILS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)/find/find
	@echo "Testing findutils $(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FINDUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/findutils.test.done: $(KEFIR_EXTERNAL_TEST_FINDUTILS_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/findutils/validate.sh "$(KEFIR_EXTERNAL_TEST_FINDUTILS_DIR)/tests.log"
	@touch "$@"
	@echo "findutils $(KEFIR_EXTERNAL_TEST_FINDUTILS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/findutils.test.done
