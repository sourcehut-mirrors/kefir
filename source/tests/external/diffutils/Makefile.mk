
KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/diffutils

KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION := 3.12
KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE_FILENAME := diffutils-$(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR)/diffutils-$(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR)/diffutils-$(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION)
KEFIR_EXTERNAL_TEST_DIFFUTILS_URL := https://gnuftp.uib.no/diffutils/$(KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE_SHA256 := 5be181b27ec38aad2450080661a64e4a1752bb29b7d5052bf0a02a70f623f9b2

$(KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_DIFFUTILS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring diffutils $(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)/src/diff: $(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)/Makefile
	@echo "Building diffutils $(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)/src/diff
	@echo "Testing diffutils $(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/diffutils.test.done: $(KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/diffutils/validate.sh "$(KEFIR_EXTERNAL_TEST_DIFFUTILS_DIR)/tests.log"
	@touch "$@"
	@echo "diffutils $(KEFIR_EXTERNAL_TEST_DIFFUTILS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/diffutils.test.done
