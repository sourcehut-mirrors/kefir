
KEFIR_EXTERNAL_TEST_JEMALLOC_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/jemalloc

KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION := 5.3.0
KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_FILENAME := jemalloc-$(KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION).tar.bz2
KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE := $(KEFIR_EXTERNAL_TEST_JEMALLOC_DIR)/$(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_JEMALLOC_DIR)/jemalloc-$(KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION)
KEFIR_EXTERNAL_TEST_JEMALLOC_URL := https://github.com/jemalloc/jemalloc/releases/download/$(KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION)/$(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_SHA256 := 2db82d1e7119df3e71b7640219b6dfe84789bc0537983c3b7ac4f7189aecfeaa

$(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_JEMALLOC_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_JEMALLOC_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_JEMALLOC_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_JEMALLOC_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configure jemalloc $(KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure --disable-cxx

$(KEFIR_EXTERNAL_TEST_JEMALLOC_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR)/Makefile
	@echo "Testing jemalloc $(KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_JEMALLOC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check -j$$(( $$(nproc) < 4 ? $$(nproc) : 4 )) 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/jemalloc.test.done: $(KEFIR_EXTERNAL_TEST_JEMALLOC_DIR)/tests.log
	@"$(SOURCE_DIR)/tests/external/jemalloc/validate.sh" "$(KEFIR_EXTERNAL_TEST_JEMALLOC_DIR)/tests.log"
	@touch "$@"
	@echo "jemalloc $(KEFIR_EXTERNAL_TEST_JEMALLOC_VERSION) test successfully finished"

EXTERNAL_TESTS_SLOW_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/jemalloc.test.done
