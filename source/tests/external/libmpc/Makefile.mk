
KEFIR_EXTERNAL_TEST_LIBMPC_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libmpc

KEFIR_EXTERNAL_TEST_LIBMPC_VERSION := 1.3.1
KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE_FILENAME := mpc-$(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBMPC_DIR)/mpc-$(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBMPC_URL := https://gnuftp.uib.no/mpc/$(KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBMPC_DIR)/mpc-$(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION)

KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE_SHA256 := ab642492f5cf882b74aa0cb730cd410a81edcdbec895183ce930e706c1c759b8

$(KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBMPC_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBMPC_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPC_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_LIBMPC_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring libmpc $(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)/src/.libs/libmpc.a: $(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)/Makefile
	@echo "Building libmpc $(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_LIBMPC_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)/src/.libs/libmpc.a
	@echo "Testing libmpc $(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBMPC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/libmpc.test.done: $(KEFIR_EXTERNAL_TEST_LIBMPC_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/libmpc/validate.sh "$(KEFIR_EXTERNAL_TEST_LIBMPC_DIR)/tests.log"
	@touch "$@"
	@echo "libmpc $(KEFIR_EXTERNAL_TEST_LIBMPC_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libmpc.test.done
