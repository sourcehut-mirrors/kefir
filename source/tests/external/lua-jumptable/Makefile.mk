KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/lua-jumptable

KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION := 5.4.8
KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_ARCHIVE := lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_ARCHIVE := lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)-tests.tar.gz
KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_URL := https://www.lua.org/ftp/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_URL := https://www.lua.org/tests/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)-tests.tar.gz

KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_ARCHIVE_SHA256=4f18ddae154e793e46eeab727c59ef1c0c0c2b744e7b94219710d76f530629ae
KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_ARCHIVE_SHA256=9581d5a7c39ffbf29b8ccde2709083c380f7bbddbd968dcb15712d2f2e33f4e5

KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_EXE := $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)/src/lua
KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_TEST_SUITE := $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)-tests/.extracted

KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_CFLAGS := -O1 -fPIC -pie -DLUA_USE_JUMPTABLE=1

$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_ARCHIVE):
	@mkdir -p $(shell dirname $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_URL)..."
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_ARCHIVE):
	@mkdir -p $(shell dirname $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_URL)..."
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_EXE): $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_ARCHIVE) $(KEFIR_EXE)
	@echo "Building Lua $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION) (jumptable)..."
	@rm -rf "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)"
	@cd "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_ARCHIVE)"
	@cd "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)" && \
		LD_LIBRARY_PATH="$(shell $(REALPATH) $(LIB_DIR)):$$LD_LIBRARY_PATH" \
		KEFIR_RTINC="$(shell $(REALPATH) $(HEADERS_DIR)/kefir/runtime)" \
			$(MAKE) -f Makefile \
			CC="$(shell $(REALPATH) $(KEFIR_EXE))" \
			CFLAGS="$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_CFLAGS)" \
			posix

$(KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_TEST_SUITE): $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_ARCHIVE)
	@echo "Extracting Lua $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION) (jumptable) tests..."
	@rm -rf "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)-tests"
	@cd "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_TESTS_ARCHIVE)"
	@cd "$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_DIR)/lua-$(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION)-tests" && patch < "$(shell $(REALPATH) $(SOURCE_DIR)/tests/external/lua/lua-5.4.6-tests.patch)"
	@touch "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/lua-jumptable.test.done: $(KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_EXE) $(KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_TEST_SUITE)
	@echo "Running Lua $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION) (jumptable) test suite..."
	@cd "$(shell dirname $(KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_TEST_SUITE))" && "$(shell $(REALPATH) $(KEFIR_EXTERAL_TEST_LUA_JUMPTABLE_EXE))" -e"_U=true" all.lua
	@touch "$@"
	@echo "Lua $(KEFIR_EXTERNAL_TEST_LUA_JUMPTABLE_VERSION) (jumptable) test suite successfully finished"

EXTERNAL_TESTS_BASE_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/lua-jumptable.test.done
