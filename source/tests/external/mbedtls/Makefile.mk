
KEFIR_EXTERNAL_TEST_MBEDTLS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/mbedtls

KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION := 4.0.0
KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_FILENAME := mbedtls-$(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION).tar.bz2
KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_MBEDTLS_DIR)/$(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_MBEDTLS_DIR)/mbedtls-$(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION)
KEFIR_EXTERNAL_TEST_MBEDTLS_URL := https://github.com/Mbed-TLS/mbedtls/releases/download/mbedtls-$(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION)/$(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_SHA256 := 2f3a47f7b3a541ddef450e4867eeecb7ce2ef7776093f3a11d6d43ead6bf2827

$(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_MBEDTLS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_MBEDTLS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MBEDTLS_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_FILENAME)"
	@echo "Patching $(KEFIR_EXTERNAL_TEST_MBEDTLS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/mbedtls/mbedtls.patch"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building mbedtls $(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		cmake .

$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)/library/libmbedtls.a: $(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)/Makefile
	@echo "Building mbedtls $(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) CC="$(realpath $(KEFIR_EXE))"

$(KEFIR_EXTERNAL_TEST_MBEDTLS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)/library/libmbedtls.a
	@echo "Testing mbedtls $(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MBEDTLS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) CC="$(realpath $(KEFIR_EXE))" test 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/mbedtls.test.done: $(KEFIR_EXTERNAL_TEST_MBEDTLS_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/mbedtls/validate.sh "$(KEFIR_EXTERNAL_TEST_MBEDTLS_DIR)/tests.log"
	@touch "$@"
	@echo "mbedtls $(KEFIR_EXTERNAL_TEST_MBEDTLS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/mbedtls.test.done
