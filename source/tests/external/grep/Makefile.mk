
KEFIR_EXTERNAL_TEST_GREP_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/grep

KEFIR_EXTERNAL_TEST_GREP_VERSION := 3.12
KEFIR_EXTERNAL_TEST_GREP_ARCHIVE_FILENAME := grep-$(KEFIR_EXTERNAL_TEST_GREP_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_GREP_ARCHIVE := $(KEFIR_EXTERNAL_TEST_GREP_DIR)/grep-$(KEFIR_EXTERNAL_TEST_GREP_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_GREP_DIR)/grep-$(KEFIR_EXTERNAL_TEST_GREP_VERSION)
KEFIR_EXTERNAL_TEST_GREP_URL := https://gnuftp.uib.no/grep/$(KEFIR_EXTERNAL_TEST_GREP_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_GREP_ARCHIVE_SHA256 := badda546dfc4b9d97e992e2c35f3b5c7f20522ffcbe2f01ba1e9cdcbe7644cdc

$(KEFIR_EXTERNAL_TEST_GREP_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_GREP_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_GREP_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_GREP_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_GREP_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_GREP_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_GREP_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_GREP_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring grep $(KEFIR_EXTERNAL_TEST_GREP_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)/src/grep: $(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)/Makefile
	@echo "Building grep $(KEFIR_EXTERNAL_TEST_GREP_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_GREP_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)/src/grep
	@echo "Testing grep $(KEFIR_EXTERNAL_TEST_GREP_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_GREP_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/grep.test.done: $(KEFIR_EXTERNAL_TEST_GREP_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/grep/validate.sh "$(KEFIR_EXTERNAL_TEST_GREP_DIR)/tests.log"
	@touch "$@"
	@echo "grep $(KEFIR_EXTERNAL_TEST_GREP_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/grep.test.done
