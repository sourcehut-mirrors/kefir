
KEFIR_EXTERNAL_TEST_FLEX_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/flex

KEFIR_EXTERNAL_TEST_FLEX_VERSION := 2.6.4
KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_FILENAME := flex-$(KEFIR_EXTERNAL_TEST_FLEX_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE := $(KEFIR_EXTERNAL_TEST_FLEX_DIR)/$(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_FLEX_DIR)/flex-$(KEFIR_EXTERNAL_TEST_FLEX_VERSION)
KEFIR_EXTERNAL_TEST_FLEX_URL := https://github.com/westes/flex/releases/download/v$(KEFIR_EXTERNAL_TEST_FLEX_VERSION)/$(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_SHA256 := e87aae032bf07c26f85ac0ed3250998c37621d95f8bd748b31f15b33c45ee995

$(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_FLEX_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_FLEX_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FLEX_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_FLEX_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Build flex $(KEFIR_EXTERNAL_TEST_FLEX_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)/src/flex: $(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)/Makefile
	@echo "Build flex $(KEFIR_EXTERNAL_TEST_FLEX_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_FLEX_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)/src/flex
	@echo "Testing flex $(KEFIR_EXTERNAL_TEST_FLEX_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_FLEX_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/flex.test.done: $(KEFIR_EXTERNAL_TEST_FLEX_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/flex/validate.sh "$(KEFIR_EXTERNAL_TEST_FLEX_DIR)/tests.log"
	@touch "$@"
	@echo "flex $(KEFIR_EXTERNAL_TEST_FLEX_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/flex.test.done
