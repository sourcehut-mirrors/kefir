
KEFIR_EXTERNAL_TEST_RSYNC_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/rsync

KEFIR_EXTERNAL_TEST_RSYNC_VERSION := 3.4.1
KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_FILENAME := rsync-$(KEFIR_EXTERNAL_TEST_RSYNC_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE := $(KEFIR_EXTERNAL_TEST_RSYNC_DIR)/$(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_RSYNC_DIR)/rsync-$(KEFIR_EXTERNAL_TEST_RSYNC_VERSION)
KEFIR_EXTERNAL_TEST_RSYNC_URL := https://github.com/RsyncProject/rsync/releases/download/v$(KEFIR_EXTERNAL_TEST_RSYNC_VERSION)/$(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_SHA256 := 2924bcb3a1ed8b551fc101f740b9f0fe0a202b115027647cf69850d65fd88c52

$(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_RSYNC_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_RSYNC_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_RSYNC_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_RSYNC_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)/.extracted
	@echo "Building rsync $(KEFIR_EXTERNAL_TEST_RSYNC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)/rsync: $(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)/Makefile
	@echo "Building rsync $(KEFIR_EXTERNAL_TEST_RSYNC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_RSYNC_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)/rsync
	@echo "Testing rsync $(KEFIR_EXTERNAL_TEST_RSYNC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_RSYNC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) test 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/rsync.test.done: $(KEFIR_EXTERNAL_TEST_RSYNC_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/rsync/validate.sh "$(KEFIR_EXTERNAL_TEST_RSYNC_DIR)/tests.log"
	@touch "$@"
	@echo "rsync $(KEFIR_EXTERNAL_TEST_RSYNC_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/rsync.test.done
