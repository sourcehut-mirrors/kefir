
KEFIR_EXTERNAL_TEST_COREMARK_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/coremark

KEFIR_EXTERNAL_TEST_COREMARK_VERSION := 1f483d5b8316753a742cbf5590caf5bd0a4e4777
KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_COREMARK_VERSION).zip
KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE := $(KEFIR_EXTERNAL_TEST_COREMARK_DIR)/$(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_COREMARK_DIR)/coremark-$(KEFIR_EXTERNAL_TEST_COREMARK_VERSION)
KEFIR_EXTERNAL_TEST_COREMARK_URL := https://github.com/eembc/coremark/archive/$(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_SHA256 := acc21470160d85e078c015f9bb1878166bfe9bf2971d8de37455556b098f4676

$(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_COREMARK_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_COREMARK_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREMARK_DIR)" && unzip -o "$(KEFIR_EXTERNAL_TEST_COREMARK_ARCHIVE_FILENAME)"
	@echo "Patching coremark $(KEFIR_EXTERNAL_TEST_COREMARK_VERSION)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run1.log: $(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building $@..."
	@mkdir -p "$(shell dirname $@)"
	@cd "$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) run1.log

$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run2.log: $(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run1.log
	@echo "Building $@..."
	@mkdir -p "$(shell dirname $@)"
	@cd "$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) run2.log
		
$(KEFIR_EXTERNAL_TESTS_DIR)/coremark.test.done: $(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run1.log \
												$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run2.log
	@$(SOURCE_DIR)/tests/external/coremark/validate.sh "$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run1.log"
	@$(SOURCE_DIR)/tests/external/coremark/validate.sh "$(KEFIR_EXTERNAL_TEST_COREMARK_SOURCE_DIR)/run2.log"
	@touch "$@"
	@echo "Successfully tested coremark $(KEFIR_EXTERNAL_TEST_COREMARK_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/coremark.test.done
