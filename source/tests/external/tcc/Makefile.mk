
KEFIR_EXTERNAL_TEST_TCC_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/tcc

KEFIR_EXTERNAL_TEST_TCC_VERSION := fada98b1ce9ee0c36771183177218828ccb9b9de
KEFIR_EXTERNAL_TEST_TCC_ARCHIVE_FILENAME := tcc-$(KEFIR_EXTERNAL_TEST_TCC_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_TCC_ARCHIVE := $(KEFIR_EXTERNAL_TEST_TCC_DIR)/$(KEFIR_EXTERNAL_TEST_TCC_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_TCC_DIR)/tinycc-fada98b
KEFIR_EXTERNAL_TEST_TCC_URL := https://repo.or.cz/tinycc.git/snapshot/$(KEFIR_EXTERNAL_TEST_TCC_VERSION).tar.gz

KEFIR_EXTERNAL_TEST_TCC_ARCHIVE_SHA256 := 7bb94122247b8f44f0af24cd3ecee0bd9bbdf2d566fe44bba473b0b2e6371d3e

$(KEFIR_EXTERNAL_TEST_TCC_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_TCC_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_TCC_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_TCC_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_TCC_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_TCC_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_TCC_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_TCC_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/config.h: $(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring tcc $(KEFIR_EXTERNAL_TEST_TCC_VERSION)..."
	@rm -f "$@"
	@cd "$(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		./configure --cc="$(realpath $(KEFIR_EXE))" --extra-cflags="-O1 -fPIC -pie"

$(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/tcc: $(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/config.h
	@echo "Building tcc $(KEFIR_EXTERNAL_TEST_TCC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		$(MAKE) all

$(KEFIR_EXTERNAL_TESTS_DIR)/tcc.test.done: $(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/tcc
	@echo "Testing tcc $(KEFIR_EXTERNAL_TEST_TCC_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_TCC_SOURCE_DIR)/tests/tests2" && $(MAKE) test
	@touch "$@"
	@echo "Successfully validated tcc $(KEFIR_EXTERNAL_TEST_TCC_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/tcc.test.done
