
KEFIR_EXTERNAL_TEST_COREUTILS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/coreutils

KEFIR_EXTERNAL_TEST_COREUTILS_VERSION := 9.10
KEFIR_EXTERNAL_TEST_GNULIB_VERSION := 1c5e0277c2143dd570d8c88f8923eed2afd8e13b
KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE_FILENAME := v$(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_GNULIB_VERSION).zip
KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/$(KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE := $(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/$(KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/coreutils-$(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)
KEFIR_EXTERNAL_TEST_GNULIB_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/coreutils-$(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)/gnulib-$(KEFIR_EXTERNAL_TEST_GNULIB_VERSION)
KEFIR_EXTERNAL_TEST_COREUTILS_URL := https://github.com/coreutils/coreutils/archive/refs/tags/v$(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_GNULIB_URL := https://github.com/coreutils/gnulib/archive/$(KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE_SHA256 := 8bd4b73f4839cdca9bafa9dcb2ffd4d2d34776d1e8b43c9e02f9f0ed468e472b
KEFIR_EXTERNAL_TEST_GNUTLS_ARCHIVE_SHA256 := 36a014493c9b99f97383b9f20ff6729a7cacbce6619081fdac576fe3247f328c

$(KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_COREUTILS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_COREUTILS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_GNULIB_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_GNULIB_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_GNUTLS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_COREUTILS_ARCHIVE_FILENAME)"
	@echo "Patching coreutils $(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/coreutils/coreutils-9.7.patch"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_GNULIB_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/.extracted $(KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE_FILENAME)..."
	@rm -rf "$(KEFIR_EXTERNAL_TEST_GNULIB_SOURCE_DIR)"
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)" && unzip "../$(KEFIR_EXTERNAL_TEST_GNULIB_ARCHIVE_FILENAME)"
	@echo "Patching gnulib $(KEFIR_EXTERNAL_TEST_GNULIB_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_GNULIB_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/coreutils/gnulib.patch"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/configure: $(KEFIR_EXTERNAL_TEST_GNULIB_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Bootstrapping coreutils $(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./bootstrap --no-git --gnulib-srcdir=$$PWD/gnulib-$(KEFIR_EXTERNAL_TEST_GNULIB_VERSION)

$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/configure
	@echo "Configuring coreutils $(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/.done: $(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/Makefile
	@echo "Building coreutils $(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)/.done
	@echo "Testing coreutils $(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_COREUTILS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check -j1 2>&1 | tee "$(shell realpath $@.tmp)"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/coreutils.test.done: $(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/coreutils/validate.sh "$(KEFIR_EXTERNAL_TEST_COREUTILS_DIR)/tests.log"
	@touch "$@"
	@echo "Coreutils $(KEFIR_EXTERNAL_TEST_COREUTILS_VERSION) test suite successfully finished"

EXTERNAL_TESTS_SLOW_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/coreutils.test.done
