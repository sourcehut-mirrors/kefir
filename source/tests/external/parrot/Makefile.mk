
KEFIR_EXTERNAL_TEST_PARROT_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/parrot

KEFIR_EXTERNAL_TEST_PARROT_VERSION := 472c0538637dedfe2fd0f29567d0c26bf9f38edd
KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_PARROT_VERSION).zip
KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE := $(KEFIR_EXTERNAL_TEST_PARROT_DIR)/$(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_PARROT_DIR)/parrot-$(KEFIR_EXTERNAL_TEST_PARROT_VERSION)
KEFIR_EXTERNAL_TEST_PARROT_URL := https://github.com/parrot/parrot/archive/$(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_SHA256 := 46b950d8abadb5a8582ebda72a751c956a1db5586150ab5743ca340acf43622e

$(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_PARROT_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_PARROT_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PARROT_DIR)" && unzip "$(KEFIR_EXTERNAL_TEST_PARROT_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Configuring parrot $(KEFIR_EXTERNAL_TEST_PARROT_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		perl Configure.pl --cc="$(realpath $(KEFIR_EXE))" --ld="$(realpath $(KEFIR_EXE))" --link="$(realpath $(KEFIR_EXE))" --linkflags=

$(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)/parrot: $(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)/Makefile
	@echo "Building parrot $(KEFIR_EXTERNAL_TEST_PARROT_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_PARROT_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)/parrot
	@echo "Testing parrot $(KEFIR_EXTERNAL_TEST_PARROT_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PARROT_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/parrot.test.done: $(KEFIR_EXTERNAL_TEST_PARROT_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/parrot/validate.sh "$(KEFIR_EXTERNAL_TEST_PARROT_DIR)/tests.log"
	@touch "$@"
	@echo "Parrot $(KEFIR_EXTERNAL_TEST_PARROT_VERSION) test suite successfully finished"

EXTERNAL_TESTS_SLOW_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/parrot.test.done
