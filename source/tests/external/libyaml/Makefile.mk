
KEFIR_EXTERNAL_TEST_LIBYAML_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libyaml

KEFIR_EXTERNAL_TEST_LIBYAML_VERSION := 840b65c40675e2d06bf40405ad3f12dec7f35923
KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION).zip
KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBYAML_DIR)/$(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBYAML_DIR)/libyaml-$(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION)
KEFIR_EXTERNAL_TEST_LIBYAML_URL := https://github.com/yaml/libyaml/archive/$(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_SHA256 := 269a8f5805b73ed7e90303eec20687ff2bfcdd29157b470c92d18eeb45c53d85

$(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBYAML_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBYAML_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBYAML_DIR)" && unzip -o "$(KEFIR_EXTERNAL_TEST_LIBYAML_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/configure: $(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Bootstrapping libyaml $(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./bootstrap

$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/configure
	@echo "Configuring libyaml $(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/src/.libs/libyaml.a: $(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/Makefile
	@echo "Configuring libyaml $(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/src/.libs/libyaml.a
	@echo "Testing libyaml $(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check | tee tests.log.tmp'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/libyaml.test.done: $(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/libyaml/validate.sh "$(KEFIR_EXTERNAL_TEST_LIBYAML_SOURCE_DIR)/tests.log"
	@touch "$@"
	@echo "Successfully tested libyaml $(KEFIR_EXTERNAL_TEST_LIBYAML_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libyaml.test.done
