
KEFIR_EXTERNAL_TEST_PIGZ_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/pigz

KEFIR_EXTERNAL_TEST_PIGZ_VERSION := 2.8
KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE_FILENAME := pigz-$(KEFIR_EXTERNAL_TEST_PIGZ_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE := $(KEFIR_EXTERNAL_TEST_PIGZ_DIR)/pigz-$(KEFIR_EXTERNAL_TEST_PIGZ_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_PIGZ_URL := https://zlib.net/pigz/$(KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_PIGZ_DIR)/pigz-$(KEFIR_EXTERNAL_TEST_PIGZ_VERSION)

KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE_SHA256 := eb872b4f0e1f0ebe59c9f7bd8c506c4204893ba6a8492de31df416f0d5170fd0

$(KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_PIGZ_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_PIGZ_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PIGZ_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_PIGZ_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR)/pigz: $(KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building pigz $(KEFIR_EXTERNAL_TEST_PIGZ_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) CC="$(realpath $(KEFIR_EXE))"

$(KEFIR_EXTERNAL_TEST_PIGZ_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR)/pigz
	@echo "Testing pigz $(KEFIR_EXTERNAL_TEST_PIGZ_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_PIGZ_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) CC="$(realpath $(KEFIR_EXE))" tests 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/pigz.test.done: $(KEFIR_EXTERNAL_TEST_PIGZ_DIR)/tests.log
	@touch "$@"
	@echo "pigz $(KEFIR_EXTERNAL_TEST_PIGZ_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/pigz.test.done
