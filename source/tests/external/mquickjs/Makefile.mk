
KEFIR_EXTERNAL_TEST_MQUICKJS_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/mquickjs

KEFIR_EXTERNAL_TEST_MQUICKJS_VERSION := ee50431eac9b14b99f722b537ec4cac0c8dd75ab
KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_MQUICKJS_VERSION).zip
KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE := $(KEFIR_EXTERNAL_TEST_MQUICKJS_DIR)/$(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_MQUICKJS_DIR)/mquickjs-$(KEFIR_EXTERNAL_TEST_MQUICKJS_VERSION)
KEFIR_EXTERNAL_TEST_MQUICKJS_URL := https://github.com/bellard/mquickjs/archive/$(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_SHA256 := e695a9382a8772c01e7612803e15b2c93423ec4e9f40f8876844d22f99b0d4bc

$(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_MQUICKJS_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_MQUICKJS_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MQUICKJS_DIR)" && unzip "$(KEFIR_EXTERNAL_TEST_MQUICKJS_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR)/mqjs: $(KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building mquickjs $(KEFIR_EXTERNAL_TEST_MQUICKJS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) CC="$(realpath $(KEFIR_EXE))"

$(KEFIR_EXTERNAL_TEST_MQUICKJS_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR)/mqjs
	@echo "Testing mquickjs $(KEFIR_EXTERNAL_TEST_MQUICKJS_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_MQUICKJS_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) CC="$(realpath $(KEFIR_EXE))" test 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/mquickjs.test.done: $(KEFIR_EXTERNAL_TEST_MQUICKJS_DIR)/tests.log
	@touch "$@"
	@echo "mquickjs $(KEFIR_EXTERNAL_TEST_MQUICKJS_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/mquickjs.test.done
