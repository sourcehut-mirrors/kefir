
KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libnettle

KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION := 4.0_release_20260205
KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME := nettle_$(KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR)/$(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR)/nettle-nettle_$(KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION)
KEFIR_EXTERNAL_TEST_LIBNETTLE_URL := https://github.com/gnutls/nettle/archive/refs/tags/$(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_SHA256 := ae832c5bfe7d2f700b17364623864818f8013c9e7c99b625abd9d5d1ffbe768b

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBNETTLE_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/ltmain.sh: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/.extracted
	@echo "Libtoolize nettle $(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)" && libtoolize
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/configure: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/.extracted
	@echo "Libtoolize nettle $(KEFIR_EXTERNAL_TEST_LIBNETTLE_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)" && autoreconf -fi
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/configure $(KEFIR_EXE)
	@echo "Configuring nettle $(KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/.lib/libnettle.so: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/Makefile
	@echo "Building nettle $(KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)/.lib/libnettle.so
	@echo "Testing nettle $(KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) check 2>&1 | tee "$(shell realpath "$@.tmp")"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/libnettle.test.done: $(KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/libnettle/validate.sh "$(KEFIR_EXTERNAL_TEST_LIBNETTLE_DIR)/tests.log"
	@touch "$@"
	@echo "nettle $(KEFIR_EXTERNAL_TEST_LIBNETTLE_VERSION) test suite successfully finished"

EXTERNAL_TESTS_SLOW_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libnettle.test.done
