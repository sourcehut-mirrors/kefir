
KEFIR_EXTERNAL_TEST_CGIT_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/cgit

KEFIR_EXTERNAL_TEST_CGIT_VERSION := 61ef851ef52c3094d12fefad3576262606fddd27
KEFIR_EXTERNAL_TEST_CGIT_GIT_VERSION := 67ad42147a7acc2af6074753ebd03d904476118f
KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_CGIT_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE_FILENAME := $(KEFIR_EXTERNAL_TEST_CGIT_GIT_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE := $(KEFIR_EXTERNAL_TEST_CGIT_DIR)/$(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE := $(KEFIR_EXTERNAL_TEST_CGIT_DIR)/$(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_CGIT_DIR)/cgit-$(KEFIR_EXTERNAL_TEST_CGIT_VERSION)
KEFIR_EXTERNAL_TEST_CGIT_GIT_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_CGIT_DIR)/git
KEFIR_EXTERNAL_TEST_CGIT_URL := https://github.com/zx2c4/cgit/archive/$(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_CGIT_GIT_URL := https://github.com/git/git/archive/$(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_SHA256 := 0611ba36ba32255a7b85fbb99453ebbf39f92c764faca2e2f370aef97b88a4a6
KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE_SHA256 := 89b73762be55037144c92eaf5d0657b644330770f66c584c1ba2e7b90b6218cf

$(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_CGIT_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_CGIT_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_CGIT_GIT_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_CGIT_GIT_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE) $(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_CGIT_DIR)" && tar xvfz "$(KEFIR_EXTERNAL_TEST_CGIT_ARCHIVE_FILENAME)"
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)" && tar xvfz "$(realpath $(KEFIR_EXTERNAL_TEST_CGIT_GIT_ARCHIVE))"
	@rm -rf "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/git"
	@mv "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/git-$(KEFIR_EXTERNAL_TEST_CGIT_GIT_VERSION)" "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/git"
	@echo "Patching cgit $(KEFIR_EXTERNAL_TEST_CGIT_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/cgit/cgit.patch"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/cgit: $(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Building cgit $(KEFIR_EXTERNAL_TEST_CGIT_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE) CC="$(realpath $(KEFIR_EXE))" all

$(KEFIR_EXTERNAL_TEST_CGIT_DIR)/tests.log: $(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)/cgit
	@echo "Testing cgit $(KEFIR_EXTERNAL_TEST_CGIT_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_CGIT_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		bash -c 'set -o pipefail; $(MAKE) CC="$(realpath $(KEFIR_EXE))" test | tee "$(shell realpath $@.tmp)"'
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TESTS_DIR)/cgit.test.done: $(KEFIR_EXTERNAL_TEST_CGIT_DIR)/tests.log
	@$(SOURCE_DIR)/tests/external/cgit/validate.sh "$(KEFIR_EXTERNAL_TEST_CGIT_DIR)/tests.log"
	@touch "$@"
	@echo "Successfully tested cgit $(KEFIR_EXTERNAL_TEST_CGIT_VERSION)"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/cgit.test.done
