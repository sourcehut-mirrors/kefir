
KEFIR_EXTERNAL_TEST_LIBWEBP_DIR := $(KEFIR_EXTERNAL_TESTS_DIR)/libwebp

KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION := 1.6.0
KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_FILENAME := v$(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION).tar.gz
KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE := $(KEFIR_EXTERNAL_TEST_LIBWEBP_DIR)/$(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_FILENAME)
KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR := $(KEFIR_EXTERNAL_TEST_LIBWEBP_DIR)/libwebp-$(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION)
KEFIR_EXTERNAL_TEST_LIBWEBP_URL := https://github.com/webmproject/libwebp/archive/refs/tags/$(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_FILENAME)

KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_SHA256 := 93a852c2b3efafee3723efd4636de855b46f9fe1efddd607e1f42f60fc8f2136

$(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE):
	@mkdir -p $(dir $@)
	@echo "Downloading $(KEFIR_EXTERNAL_TEST_LIBWEBP_URL)"
	@$(WGET) -O "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBWEBP_URL)"
	@$(SCRIPTS_DIR)/checksum_sha256.sh "$@.tmp" "$(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_SHA256)"
	@mv "$@.tmp" "$@"

$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/.extracted: $(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE)
	@echo "Extracting $(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBWEBP_DIR)" && tar xvf "$(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_FILENAME)"
	@touch "$@"

$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/configure: $(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/.extracted $(KEFIR_EXE)
	@echo "Build libwebp $(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		sh autogen.sh
	@echo "Patching libwebp $(KEFIR_EXTERNAL_TEST_LIBWEBP_ARCHIVE_FILENAME)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)" && patch -p0 < "$(realpath $(SOURCE_DIR))/tests/external/libwebp/libwebp.patch"

$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/Makefile: $(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/configure
	@echo "Build libwebp $(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		./configure

$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/examples/dwebp: $(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/Makefile
	@echo "Build libwebp $(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION)..."
	@cd "$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)" && \
		LD_LIBRARY_PATH="$(realpath $(LIB_DIR))$(if $(LD_LIBRARY_PATH),:$(LD_LIBRARY_PATH))" \
		KEFIR_RTINC="$(realpath $(HEADERS_DIR))/kefir/runtime" \
		CC="$(realpath $(KEFIR_EXE))" \
		$(MAKE)

$(KEFIR_EXTERNAL_TESTS_DIR)/libwebp.test.done: $(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)/examples/dwebp
	@echo "Testing libwebp $(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION)..."
	@$(SOURCE_DIR)/tests/external/libwebp/test.sh "$(KEFIR_EXTERNAL_TEST_LIBWEBP_SOURCE_DIR)"
	@touch "$@"
	@echo "libwebp $(KEFIR_EXTERNAL_TEST_LIBWEBP_VERSION) test successfully finished"

EXTERNAL_TESTS_FAST_SUITE += $(KEFIR_EXTERNAL_TESTS_DIR)/libwebp.test.done
